APP_NAME=FleetGuardian AI
APP_VERSION=1.0.0
ENVIRONMENT=development

API_PREFIX=/api/v1

HOST=0.0.0.0
PORT=8000

# Local PostgreSQL example.
# Replace CHANGE_ME with your local PostgreSQL password.
DATABASE_URL=postgresql+psycopg://postgres:CHANGE_ME@localhost:5432/fleetguardian_ai

# Docker Compose PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://fleetguardian:fleetguardian_dev_password@postgres:5432/fleetguardian_ai

DB_ECHO=false
CREATE_DB_TABLES_ON_STARTUP=true

LOG_LEVEL=INFO
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174
